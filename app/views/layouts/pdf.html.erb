<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type">
  </head>
  <style>
    body {
      font-family: Arial, sans-serif;
      color: #1f2937;
      line-height: 1.6;
    }

    .title {
      font-size: 24px;
      font-weight: bold;
      margin-bottom: 16px;
    }

    .meta {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 8px;
    }

    .categories {
      margin-bottom: 24px;
    }

    .category {
      display: inline-block;
      background: #dcfce7;
      border: 1px solid #bbf7d0;
      border-radius: 9999px;
      padding: 4px 12px;
      margin-right: 8px;
      font-size: 12px;
    }

    .description {
      font-size: 14px;
      white-space: pre-wrap;
    }
  </style>
  <body>
    <div id="content"><%= yield %></div>
  </body>
</html>
